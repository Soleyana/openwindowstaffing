PORT=5000
MONGODB_URI=mongodb://localhost:27017/openwindowstaffing
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Optional: default company for new jobs
DEFAULT_COMPANY=Open Window Staffing

# Required in production
CLIENT_URL=https://your-frontend-domain.com
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Cookie options (production cross-domain)
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true

# Email (Resend). Required for newsletter, password reset, contact form, invite, etc.
# Get key at https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_REPLY_TO=
CONTACT_EMAIL=

# Production: set EMAIL_FROM, EMAIL_REPLY_TO, CONTACT_EMAIL in hosting env.
# Example company contact: jobs@openwindowstaffing.com (used for CONTACT_EMAIL, EMAIL_REPLY_TO).
# Local dev: Resend sandbox (onboarding@resend.dev) works without domain verification but has limits.
# FROM_EMAIL=onboarding@resend.dev

# Temporary: redirect all outgoing emails to one address (testing only). Omit to disable.
# TEST_EMAIL_OVERRIDE=

# Rate limiting: set to true for local dev only (avoids "too many login attempts" while testing).
# NEVER set in production. Omit or leave false.
# RATE_LIMIT_DISABLED=true

# Background jobs (Agenda). Set to true in production to run job expiry, digest, reminders.
# Omit in test (npm test) so tests don't hang. Optional in dev.
# ENABLE_BACKGROUND_JOBS=true

# Incident response: set EMAIL_DISABLED=true to stop all outbound emails (logged only).
# EMAIL_DISABLED=true

# Safe mode: disable outbound email (incident response). See docs/OPS.md.
# EMAIL_DISABLED=true

# Logging: pino log level (error, warn, info, debug). Default: info
# LOG_LEVEL=info

# Storage (S3/R2). When set, resumes upload to cloud instead of local disk.
# Leave unset to use local uploads/ folder.
# STORAGE_BUCKET=your-bucket
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_PUBLIC_URL_BASE=https://pub-xxx.r2.dev/your-bucket
